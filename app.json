{
  "expo": {
    "name": "E4 @ELURU",
    "slug": "e4-app",
    "scheme": "efour",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/images/E4LOGO.jpeg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.efour.eluru",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.efour.eluru",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "efour"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./public/images/E4LOGO.jpeg",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7748edda-d363-45e7-b253-309fe59ac86e"
      }
    },
    "owner": "kick_143"
  }
}
